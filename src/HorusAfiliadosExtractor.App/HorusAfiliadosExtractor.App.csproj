<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <AssemblyName>HorusBotHF</AssemblyName>
    <RootNamespace>HorusAfiliadosExtractor.App</RootNamespace>
    <Version>1.0.2</Version>
    <Company>Horus FPS</Company>
    <Product>Bot HF - Extractor de Afiliados</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Playwright" Version="1.49.0" />
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Velopack" Version="0.0.1298" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\cedulas.template.csv" />
  </ItemGroup>
</Project>
